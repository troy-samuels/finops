{
  "name": "@costpane/github-action",
  "version": "1.0.0",
  "description": "GitHub Action for AI cost tracking and budget enforcement",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/main.ts --format esm --target node20 --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src __tests__"
  },
  "keywords": [
    "github-action",
    "ai",
    "cost-tracking",
    "openai",
    "anthropic",
    "google-ai"
  ],
  "author": "CostPane",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
